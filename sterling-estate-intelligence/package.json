{
  "name": "sterling-estate-intelligence",
  "version": "1.0.0",
  "description": "Global land development intelligence system for Sterling Intelligence Group",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "cd client && vite",
    "build": "cd client && vite build",
    "start": "node server/index.js",
    "lint": "eslint .",
    "test": "vitest"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "axios": "^1.4.0",
    "node-fetch": "^3.3.0",
    "pg": "^8.11.0",
    "redis": "^4.6.0",
    "bull": "^4.11.0",
    "mapbox-gl": "^2.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "wouter": "^3.0.0",
    "zustand": "^4.3.0",
    "axios": "^1.4.0"
  },
  "devDependencies": {
    "vite": "^4.4.0",
    "@vitejs/plugin-react": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.45.0",
    "vitest": "^0.34.0"
  }
}
